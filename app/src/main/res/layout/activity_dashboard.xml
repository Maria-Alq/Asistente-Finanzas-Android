<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- BOTÓN TEMPORAL: Para simular el Día 1 del mes -->
        <Button
            android:id="@+id/btnSimularMes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⌚ Simular Fin de Mes"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF0000"
            android:layout_gravity="start"
            android:layout_marginBottom="5dp"/>

        <Button
            android:id="@+id/btnNuevaCategoria"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ Nueva Categoría"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4A7BFE"
            android:layout_gravity="end"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="FUTURO"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:textAlignment="center"
            android:layout_marginBottom="10dp"/>

        <ProgressBar
            android:id="@+id/barraFuturo"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:progress="45"
            android:max="100"
            android:progressTint="#00FF00"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Llevas el 45% asegurado para el próximo mes."
            android:textSize="14sp"
            android:textColor="#333333"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PRESENTE"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:textAlignment="center"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="10dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerCategorias"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="80dp"/>

    </LinearLayout>

    <Button
        android:id="@+id/btnRegistrar"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:text="+"
        android:textSize="40sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#80FF80"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="30dp"/>

</RelativeLayout>