<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#EAEAEA"
    android:padding="15dp"
    android:layout_marginBottom="10dp"
    android:elevation="2dp">

    <TextView
        android:id="@+id/txtNombreCategoria"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nombre Gasto"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="10dp"/>

    <ProgressBar
        android:id="@+id/barraProgresoCategoria"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="15dp"
        android:progress="0"
        android:max="100"
        android:progressTint="#FF8C00"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/txtValoresCategoria"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Disponible: $0.00 / $0.00"
        android:textColor="#333333"
        android:layout_marginBottom="5dp"/>

    <TextView
        android:id="@+id/txtCuentaAsociada"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Origen: Banco"
        android:textColor="#555555"
        android:textSize="12sp"/>
</LinearLayout>