<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="30dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Añadir Nuevo Gasto"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:textAlignment="center"
        android:layout_marginBottom="30dp"/>

    <EditText
        android:id="@+id/txtNombreGasto"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="Nombre (Ej. Luz, Gimnasio)"
        android:backgroundTint="#FF8C00"
        android:padding="15dp"
        android:layout_marginBottom="20dp" />

    <EditText
        android:id="@+id/txtMetaMensual"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="Meta Mensual ($)"
        android:inputType="numberDecimal"
        android:backgroundTint="#FF8C00"
        android:padding="15dp"
        android:layout_marginBottom="20dp" />

    <EditText
        android:id="@+id/txtIdCuenta"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="ID Cuenta (1=Diario, 2=Ahorro)"
        android:inputType="number"
        android:backgroundTint="#FF8C00"
        android:padding="15dp"
        android:layout_marginBottom="40dp" />

    <Button
        android:id="@+id/btnGuardarCategoria"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Guardar Categoría"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:backgroundTint="#80FF80" />

</LinearLayout>